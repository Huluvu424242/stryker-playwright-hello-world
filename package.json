{
  "name": "stryker-playwright-hello-world",
  "version": "1.0.0",
  "description": "Minimales Beispiel für Mutation Testing mit Stryker und Playwright E2E-Tests.",
  "type": "module",
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "test:e2e": "playwright test --workers=1",
    "mutation": "stryker run"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "vite": "^7.3.6"
  }
}
